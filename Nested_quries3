CREATE TABLE Product (
    pid INT PRIMARY KEY,
    pname VARCHAR(20),
    price INT
);

CREATE TABLE Orders (
    oid INT PRIMARY KEY,
    customer_name VARCHAR(20),
    pid INT,
    FOREIGN KEY (pid) REFERENCES Product(pid)
);

