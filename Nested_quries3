SELECT pname, price
FROM Product
WHERE price > (SELECT AVG(price) FROM Product);

SELECT pname
FROM Product
WHERE pid IN
      (SELECT pid FROM Orders WHERE customer_name='Ravi');

SELECT pname, price
FROM Product
WHERE price =
      (SELECT MAX(price) FROM Product);
